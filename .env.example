# =============================================================================
# obsidian-git-backup-docker — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the required values.
#
# SECURITY: Do not commit your .env file! It contains secrets.
# The project .gitignore already excludes .env files.
#
# Required variables are marked with [REQUIRED].
# Optional variables show their default values.
# =============================================================================

# [REQUIRED] Obsidian account auth token.
#
# NOTE: This variable name is set by obsidian-headless, not this project.
# It does not use the OBSIDIAN_GIT_ prefix because ob reads it directly.
#
# To get your token:
#   1. Install obsidian-headless: npm install -g obsidian-headless
#   2. Run: ob login  (follow the prompts)
#   3. Copy the contents of the auth_token file:
#        Linux: ~/.config/obsidian-headless/auth_token
#        macOS: ~/.obsidian-headless/auth_token
#      The file contains the raw token string (not JSON).
#
# WARNING: Anyone with this token can access all your synced vaults.
#
# See: https://help.obsidian.md/headless
OBSIDIAN_AUTH_TOKEN=

# [REQUIRED] Name or ID of the remote vault to sync.
# Run `ob sync-list-remote` to see available vaults.
OBSIDIAN_GIT_VAULT_NAME=

# [REQUIRED] Git remote URL (SSH).
# Example: git@github.com:username/vault-backup.git
OBSIDIAN_GIT_REMOTE_URL=

# Git commit author name.
# Default: obsidian-git-backup
#OBSIDIAN_GIT_USER_NAME=obsidian-git-backup

# Git commit author email.
# Default: obsidian-git-backup@local
#OBSIDIAN_GIT_USER_EMAIL=obsidian-git-backup@local

# Git branch to commit and push to.
# Default: main
#OBSIDIAN_GIT_BRANCH=main

# Seconds of filesystem quiet before committing.
# After detecting changes, the watcher waits this long for more changes
# before committing. This prevents partial commits during active syncs.
# For large vaults, consider increasing this to 60 or higher.
# Must be a positive integer.
# Default: 30
#OBSIDIAN_GIT_DEBOUNCE_SECS=30

# How often (in seconds) to check the remote for changes when no local
# files have changed. This catches remote-only changes (e.g., someone
# pushes directly to the git repo). Set to 0 to disable periodic pulling
# (only pull before each push).
# Must be a non-negative integer (seconds).
# Minimum: 10 (when enabled). Default: 3600 (1 hour).
#OBSIDIAN_GIT_PULL_INTERVAL=3600

# End-to-end encryption password for the Obsidian vault.
# Only needed if the vault uses E2E encryption.
#OBSIDIAN_GIT_E2EE_PASSWORD=

# =============================================================================
# Obsidian Sync filtering
# =============================================================================
# Control which file types and config categories Obsidian Sync downloads.
# These are passed to `ob sync-config` on each container start.
#
# File types: which attachment types to sync.
# Valid values: image, audio, video, pdf, unsupported
# "unsupported" includes any file extension not recognized by Obsidian
# (e.g., .blend, .psd, .ai).
# Default: image,audio,video,pdf (all standard attachment types)
#OBSIDIAN_GIT_SYNC_FILE_TYPES=image,audio,video,pdf

# Config categories: which .obsidian settings to sync.
# Valid values: app, appearance, appearance-data, hotkey,
#   core-plugin, core-plugin-data, community-plugin, community-plugin-data
#
# The default does NOT include community-plugin or community-plugin-data.
# Add them if you want community plugin installations and settings synced.
# Default: app,appearance,appearance-data,hotkey,core-plugin,core-plugin-data
#OBSIDIAN_GIT_SYNC_CONFIGS=app,appearance,appearance-data,hotkey,core-plugin,core-plugin-data

# =============================================================================
# Git LFS (Large File Storage) — optional, disabled by default
# =============================================================================
# When enabled, binary files (images, PDFs, videos, etc.) are stored via
# Git LFS instead of directly in the git repository. This keeps the repo
# small and cloning fast even with large attachments.
#
# Disabled by default because many git servers do not have LFS enabled.
# To enable, uncomment the line below and ensure your git remote supports LFS
# (GitHub, GitLab, Gitea, Forgejo, Bitbucket all do).
#
# NOTE: GitHub Free includes 1 GB LFS storage + 1 GB/month bandwidth.
# See README for the default extension list and customization options.
# Default: false
#OBSIDIAN_GIT_LFS_ENABLED=true

# Comma-separated list of file extensions to track via LFS.
# Only used when LFS is enabled. Leading dots are stripped automatically.
#
# WARNING: Setting this REPLACES the entire default list — it is NOT additive.
# To add one extension, copy the full default list and append yours.
#
# Default covers common binary formats found in Obsidian vaults:
#   images, video, audio, documents, archives, fonts
#OBSIDIAN_GIT_LFS_EXTENSIONS=png,jpg,jpeg,gif,bmp,webp,tif,tiff,mp4,mov,avi,mkv,webm,mp3,wav,ogg,flac,m4a,aac,pdf,doc,docx,xls,xlsx,ppt,pptx,zip,tar,gz,7z,rar,woff,woff2,ttf,otf

# =============================================================================
# Container user identity (PUID/PGID)
# =============================================================================
# Set these to your host user's UID and GID when using bind mounts
# (e.g., ./obsidian-config:/config) to avoid "permission denied" errors.
#
# Required on macOS with bind mounts.
# Recommended on Linux with bind mounts.
# Not needed when using Docker named volumes (the default).
#
# Find your values:
#   macOS:  id -u → 501,  id -g → 20   (typical)
#   Linux:  id -u → 1000, id -g → 1000 (typical)
#
# Default: 1000 (both)
#PUID=1000
#PGID=1000
